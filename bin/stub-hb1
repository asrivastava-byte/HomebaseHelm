# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def now_iso
  Time.now.utc.strftime("%Y-%m-%dT%H:%M:%SZ")
end

def json_response(res, status, body)
  res.status = status
  res["Content-Type"] = "application/json"
  res.body = body.to_json
end

def search(collection, q, *fields)
  return collection.values if q.nil? || q.strip.empty?
  q_down = q.downcase
  collection.values.select { |r| fields.any? { |f| r[f].to_s.downcase.include?(q_down) } }
end

# ---------------------------------------------------------------------------
# Router
# ---------------------------------------------------------------------------

server = WEBrick::HTTPServer.new(
  Port: 9999,
  Logger: WEBrick::Log.new(File::NULL),
  AccessLog: []
)

server.mount_proc "/" do |req, res|
  method = req.request_method
  path   = req.path.chomp("/")
  params = req.query

  # Users — search
  if method == "GET" && path == "/api/rpa_api/v1/users"
    json_response(res, 200, search(USERS, params["q"], "full_name", "email"))

  # Users — show
  elsif method == "GET" && (m = path.match(%r{\A/api/rpa_api/v1/users/(\d+)\z}))
    user = USERS[m[1].to_i]
    user ? json_response(res, 200, user) : json_response(res, 404, { "error" => "not found" })

  # Users — update
  elsif method == "PATCH" && (m = path.match(%r{\A/api/rpa_api/v1/users/(\d+)\z}))
    user = USERS[m[1].to_i]
    if user
      body = JSON.parse(req.body || "{}")
      %w[email phone full_name].each { |f| user[f] = body[f] if body.key?(f) }
      json_response(res, 200, user)
    else
      json_response(res, 404, { "error" => "not found" })
    end

  # Users — verification SMS
  elsif method == "POST" && (m = path.match(%r{\A/api/rpa_api/v1/users/(\d+)/verification_sms\z}))
    USERS[m[1].to_i] ?
      json_response(res, 201, { "sent_at" => now_iso, "provider_request_id" => "twilio-#{SecureRandom.hex(6)}" }) :
      json_response(res, 404, { "error" => "not found" })

  # Users — verification email
  elsif method == "POST" && (m = path.match(%r{\A/api/rpa_api/v1/users/(\d+)/verification_email\z}))
    user = USERS[m[1].to_i]
    user ?
      json_response(res, 201, { "sent_at" => now_iso, "provider_request_id" => "sg-#{SecureRandom.hex(6)}", "to_email" => user["email"] }) :
      json_response(res, 404, { "error" => "not found" })

  # Users — impersonation token
  elsif method == "POST" && (m = path.match(%r{\A/api/rpa_api/v1/users/(\d+)/impersonation_token\z}))
    user = USERS[m[1].to_i]
    user ?
      json_response(res, 201, { "url" => "http://localhost:9999/login_as/#{m[1]}/#{SecureRandom.hex(12)}", "expires_at" => (Time.now.utc + 600).strftime("%Y-%m-%dT%H:%M:%SZ") }) :
      json_response(res, 404, { "error" => "not found" })

  # Companies — search
  elsif method == "GET" && path == "/api/rpa_api/v1/companies"
    json_response(res, 200, search(COMPANIES, params["q"], "name").map { |c| c.reject { |k, _| k.start_with?("_") } })

  # Companies — show
  elsif method == "GET" && (m = path.match(%r{\A/api/rpa_api/v1/companies/(\d+)\z}))
    company = COMPANIES[m[1].to_i]
    company ?
      json_response(res, 200, company.reject { |k, _| k.start_with?("_") }) :
      json_response(res, 404, { "error" => "not found" })

  # Companies — merchant profile
  elsif method == "GET" && (m = path.match(%r{\A/api/rpa_api/v1/companies/(\d+)/merchant_profile\z}))
    company = COMPANIES[m[1].to_i]
    company ?
      json_response(res, 200, company["_merchant_profile"]) :
      json_response(res, 404, { "error" => "not found" })

  # Companies — sales tax
  elsif method == "GET" && (m = path.match(%r{\A/api/rpa_api/v1/companies/(\d+)/sales_tax\z}))
    company = COMPANIES[m[1].to_i]
    company ?
      json_response(res, 200, company["_sales_tax"]) :
      json_response(res, 404, { "error" => "not found" })

  # Companies — biller
  elsif method == "GET" && (m = path.match(%r{\A/api/rpa_api/v1/companies/(\d+)/biller\z}))
    company = COMPANIES[m[1].to_i]
    company ?
      json_response(res, 200, company["_biller"]) :
      json_response(res, 404, { "error" => "not found" })

  # Companies — change billing tier
  elsif method == "POST" && (m = path.match(%r{\A/api/rpa_api/v1/companies/(\d+)/billing_tier\z}))
    company = COMPANIES[m[1].to_i]
    body    = JSON.parse(req.body || "{}")
    to_tier = body["to_tier"]
    if company.nil?
      json_response(res, 404, { "error" => "not found" })
    elsif to_tier.nil? || to_tier.strip.empty?
      json_response(res, 400, { "error" => "to_tier is required" })
    else
      from_tier    = company["tier"]
      effective_at = now_iso
      company["tier"] = to_tier
      company["_merchant_profile"]["tier"] = to_tier
      company["_biller"]["tier_history"].each { |e| e["ended_at"] = effective_at if e["ended_at"].nil? }
      company["_biller"]["tier_history"].unshift("tier" => to_tier, "started_at" => effective_at, "ended_at" => nil)
      json_response(res, 201, { "from_tier" => from_tier, "to_tier" => to_tier, "effective_at" => effective_at })
    end

  # Locations — search
  elsif method == "GET" && path == "/api/rpa_api/v1/locations"
    json_response(res, 200, search(LOCATIONS, params["q"], "name"))

  # Locations — show
  elsif method == "GET" && (m = path.match(%r{\A/api/rpa_api/v1/locations/(\d+)\z}))
    loc = LOCATIONS[m[1].to_i]
    loc ? json_response(res, 200, loc) : json_response(res, 404, { "error" => "not found" })

  # Locations — archive jobs
  elsif method == "POST" && (m = path.match(%r{\A/api/rpa_api/v1/locations/(\d+)/archive_jobs\z}))
    loc = LOCATIONS[m[1].to_i]
    if loc
      count = loc["job_count"]
      loc["archived_job_count"] += count
      loc["job_count"] = 0
      json_response(res, 201, { "archived_job_count" => count, "archived_at" => now_iso })
    else
      json_response(res, 404, { "error" => "not found" })
    end

  # Locations — unarchive jobs
  elsif method == "POST" && (m = path.match(%r{\A/api/rpa_api/v1/locations/(\d+)/unarchive_jobs\z}))
    loc = LOCATIONS[m[1].to_i]
    if loc
      count = loc["archived_job_count"]
      loc["job_count"] += count
      loc["archived_job_count"] = 0
      json_response(res, 201, { "unarchived_job_count" => count, "unarchived_at" => now_iso })
    else
      json_response(res, 404, { "error" => "not found" })
    end

  # Impersonation landing page
  elsif method == "GET" && (m = path.match(%r{\A/login_as/(\d+)/}))
    user = USERS[m[1].to_i]
    name  = user ? user["full_name"] : "Unknown User"
    email = user ? user["email"]     : ""
    phone = user ? user["phone"]     : ""
    mfa   = user ? user["mfa_status"] : "unknown"
    bank  = user ? user["bank_account_present"] : false

    memberships = user ? user["memberships"] : []
    jobs        = user ? user["jobs"]        : []

    membership_rows = memberships.map { |mem|
      "<tr><td>#{mem['company_name']}</td><td>#{mem['location_name']}</td><td><span class='role-chip'>#{mem['role_at_location']}</span></td><td class='muted'>#{mem['since'][0,10]}</td></tr>"
    }.join

    job_rows = jobs.map { |j|
      date = j["scheduled_for"] ? j["scheduled_for"][0,10] : "—"
      "<tr><td>#{j['title']}</td><td>#{j['location_name']}</td><td><span class='status-chip #{j['status']}'>#{j['status']}</span></td><td class='muted'>#{date}</td></tr>"
    }.join

    mfa_color = mfa == "enabled" ? "#16a34a" : "#dc2626"
    bank_color = bank ? "#16a34a" : "#6b7280"
    bank_label = bank ? "On file" : "Not on file"

    res.status = 200
    res["Content-Type"] = "text/html"
    res.body = <<~HTML
      <!DOCTYPE html>
      <html>
      <head>
        <meta charset="utf-8">
        <title>#{name} — Homebase</title>
        <style>
          *, *::before, *::after { box-sizing: border-box; }
          body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                 background: #f3f4f6; margin: 0; color: #111827; }
          .topbar { background: #111827; color: white; padding: 0 32px;
                    height: 52px; display: flex; align-items: center; justify-content: space-between; }
          .topbar-logo { font-weight: 700; font-size: 16px; letter-spacing: -.02em; }
          .impersonation-banner { background: #fef3c7; border-bottom: 1px solid #fde68a;
                                  padding: 10px 32px; display: flex; align-items: center; gap: 10px;
                                  font-size: 13px; color: #92400e; }
          .impersonation-banner strong { font-weight: 600; }
          .banner-dot { width: 8px; height: 8px; border-radius: 50%; background: #f59e0b;
                        flex-shrink: 0; animation: pulse 2s infinite; }
          @keyframes pulse { 0%,100% { opacity:1 } 50% { opacity:.4 } }
          .container { max-width: 900px; margin: 32px auto; padding: 0 24px; }
          .profile-card { background: white; border-radius: 10px; padding: 28px 32px;
                          box-shadow: 0 1px 2px rgba(0,0,0,.06); display: flex;
                          align-items: center; gap: 24px; margin-bottom: 24px; }
          .avatar { width: 64px; height: 64px; border-radius: 50%; background: #e5e7eb;
                    display: flex; align-items: center; justify-content: center;
                    font-size: 22px; font-weight: 700; color: #6b7280; flex-shrink: 0; }
          .profile-info h1 { font-size: 20px; font-weight: 700; margin: 0 0 4px; }
          .profile-info .email { font-size: 14px; color: #6b7280; margin: 0 0 12px; }
          .meta-chips { display: flex; gap: 8px; flex-wrap: wrap; }
          .chip { display: inline-flex; align-items: center; gap: 5px; font-size: 12px;
                  font-weight: 500; padding: 3px 10px; border-radius: 9999px;
                  background: #f3f4f6; color: #374151; border: 1px solid #e5e7eb; }
          .chip .dot { width: 7px; height: 7px; border-radius: 50%; }
          .section { background: white; border-radius: 10px;
                     box-shadow: 0 1px 2px rgba(0,0,0,.06); margin-bottom: 24px; overflow: hidden; }
          .section-header { padding: 16px 24px; border-bottom: 1px solid #f3f4f6;
                            font-size: 13px; font-weight: 600; color: #374151;
                            text-transform: uppercase; letter-spacing: .05em; }
          table { width: 100%; border-collapse: collapse; }
          td { padding: 12px 24px; font-size: 14px; border-bottom: 1px solid #f9fafb; }
          tr:last-child td { border-bottom: none; }
          .muted { color: #9ca3af; font-size: 13px; }
          .role-chip { background: #ede9fe; color: #6d28d9; font-size: 11px; font-weight: 600;
                       padding: 2px 8px; border-radius: 9999px; text-transform: capitalize; }
          .status-chip { font-size: 11px; font-weight: 600; padding: 2px 8px;
                         border-radius: 9999px; text-transform: capitalize; }
          .status-chip.active { background: #dcfce7; color: #16a34a; }
          .status-chip.archived { background: #f3f4f6; color: #6b7280; }
          .empty { padding: 24px; text-align: center; color: #9ca3af; font-size: 14px; }
        </style>
      </head>
      <body>
        <div class="topbar">
          <span class="topbar-logo">Homebase</span>
          <span style="font-size:13px;color:#9ca3af;">#{email}</span>
        </div>
        <div class="impersonation-banner">
          <div class="banner-dot"></div>
          <span>Impersonation session active — logged in as <strong>#{name}</strong>. Actions taken here are not audited.</span>
        </div>
        <div class="container">

          <div class="profile-card">
            <div class="avatar">#{name.split.map(&:chr).first(2).join.upcase}</div>
            <div class="profile-info">
              <h1>#{name}</h1>
              <div class="email">#{email}</div>
              <div class="meta-chips">
                <span class="chip">
                  <span class="dot" style="background:#{mfa_color}"></span>
                  MFA #{mfa}
                </span>
                <span class="chip">
                  <span class="dot" style="background:#{bank_color}"></span>
                  Bank #{bank_label}
                </span>
                #{phone.empty? ? '' : "<span class='chip'>#{phone}</span>"}
              </div>
            </div>
          </div>

          <div class="section">
            <div class="section-header">Locations &amp; Memberships</div>
            #{memberships.empty? ? "<div class='empty'>No memberships</div>" : "<table>#{membership_rows}</table>"}
          </div>

          <div class="section">
            <div class="section-header">Upcoming Shifts</div>
            #{jobs.empty? ? "<div class='empty'>No upcoming shifts</div>" : "<table>#{job_rows}</table>"}
          </div>

        </div>
      </body>
      </html>
    HTML

  else
    json_response(res, 404, { "error" => "not found" })
  end
end

trap("INT")  { server.shutdown }
trap("TERM") { server.shutdown }

$stdout.puts "[stub-hb1] listening on http://localhost:9999"
$stdout.flush
server.start
